@model mct_timer.Models.Personalization

@{
    ViewData["Title"] = "Set your timer";
}

<div id="gbmainbg" style="overflow: auto">
    <div id="menu" class="menu">
        <img class="option" src="~/icons/home-w.png" title="back to home" onclick="javascript:location.href = '/'" />
        <img class="option" src="~/icons/gear-w.png" title="settings" onclick="javascript:location.href='/sets'" />
        <img class="option" src="~/icons/info-w.png" title="info" onclick="javascript:location.href='/info'" />
    </div>
    <div id="loc" class="location">
        <a href="https://maps.app.goo.gl/hbQkUNNToMNu8HFx9" target="_blank">
            <img class="option" src="~/icons/location-w.png" title="image info" />
        </a>
    </div>

    <div id="location-info">
        Turkey, Kekova
    </div>

    <div id="preset-secondbg">
        <div class="setup-layout">
            <main class="setup-main">
                <div id="timer-go">
                    <div class="timer-defaults">
                        <table cellpadding="0" cellspacing="0" style="width:100%">
                            <tr>
                                <td class="title" style="flex-wrap:nowrap">time zone</td>
                                <td align="right"><img id="def-tz" src="~/icons/def-tz.png" height="20px" style="cursor:pointer" title="current location" /></td>
                            </tr>
                            <tr>
                                <td colspan="2">
                                    <select id="timezone"></select>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div id="timer-set-go">
                        <div class="custom-timer">
                            <div class="timer-heading">
                                <span class="title">start timer:</span>
                                <span class="type-icon-row">
                                    <img class="type-icons" src="~/icons/coffee-b.png" tp="coffee"/>
                                    <img class="type-icons" src="~/icons/lunch-b.png" tp="lunch"/>
                                    <img class="type-icons" src="~/icons/lab-b.png" tp="lab" />
                                    <img class="type-icons" id="def-type-icons" src="~/icons/wait-b.png" tp="wait" />
                                </span>
                            </div>
                            <div class="timer-go-set">
                                <input id="brtype" type="hidden" value="wait" />
                                <input id="datevalue" type="hidden" value="" />
                                <input id="custom-input" type="text" value="" />
                                <select id="ampm">
                                    <option value="AM">AM</option>
                                    <option value="PM">PM</option>
                                </select>
                                <span class="button" id="go"><b>START</b></span>
                            </div>

                            <div class="session-setup">
                                <label class="title" for="session-title">Session title</label>
                                <input id="session-title" type="text" maxlength="120" placeholder="Course, module, or break title" />

                                <div class="session-grid">
                                    <div>
                                        <label for="customer-name">Customer</label>
                                        <input id="customer-name" type="text" maxlength="120" placeholder="Customer or audience" />
                                    </div>
                                    <div>
                                        <label for="session-location">Region/location</label>
                                        <input id="session-location" type="text" maxlength="120" placeholder="City, region, or room" />
                                    </div>
                                    <div>
                                        <label for="class-hours">Class hours</label>
                                        <input id="class-hours" type="text" maxlength="120" placeholder="9:00 AM - 5:00 PM" />
                                    </div>
                                    <div>
                                        <label for="instructor-name">Instructor</label>
                                        <input id="instructor-name" type="text" maxlength="120" placeholder="Instructor name" />
                                    </div>
                                    <div>
                                        <label for="instructor-linkedin">Instructor LinkedIn</label>
                                        <input id="instructor-linkedin" type="url" maxlength="240" placeholder="https://www.linkedin.com/in/name" />
                                    </div>
                                    <div>
                                        <label for="instructor-qr">Instructor QR code image</label>
                                        <input id="instructor-qr" type="text" inputmode="url" autocomplete="url" maxlength="240" placeholder="/profile/linkedin-qr.png or public image URL" />
                                    </div>
                                </div>

                                <label class="session-option">
                                    <input id="ai-background" type="checkbox" />
                                    Use AI to create a background from the session title and context
                                </label>

                                <div class="session-bg-upload">
                                    <label class="title" for="custom-bg-file">Custom background image</label>
                                    <div class="session-bg-row">
                                        <input id="custom-bg-file" type="file" accept="image/png,image/jpeg,image/webp" />
                                        <button id="custom-bg-clear" type="button">clear</button>
                                    </div>
                                    <input id="custom-bg-url" type="hidden" value="" />
                                    <div id="custom-bg-status" class="session-bg-status" aria-live="polite">Optional. Overrides Bing daily and AI backgrounds.</div>
                                </div>
                            </div>

                            <div class="spotify-setup">
                                <label class="title" for="spotify-playlist">Spotify Playlist</label>
                                <div class="spotify-input-row">
                                    <input id="spotify-playlist" type="text" placeholder="Playlist URL, URI, embed URL, or ID" />
                                    <button id="spotify-playlist-clear" type="button">clear</button>
                                </div>
                                <div id="spotify-playlist-error" class="spotify-error" aria-live="polite"></div>
                            </div>

                            <div class="showcase-setup">
                                <label class="title" for="showcase-media">Showcase media</label>
                                <input id="showcase-media" type="url" placeholder="Image, GIF, MP4/WebM/Ogg, YouTube, or Vimeo URL" />
                                <input id="showcase-caption" type="text" maxlength="160" placeholder="Optional caption or call to action" />
                            </div>

                            <div class="adds-group">
                                <span class="adds-buttons" id="tophour">top hour</span>
                                <span class="adds-buttons" id="plus1">+1 min</span>
                                <span class="adds-buttons" id="minus1">-1 min</span>
                                <span class="adds-buttons" id="plus5">+5 min</span>
                                <span class="adds-buttons" id="plus10">+10 min</span>
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <aside class="setup-quick-panel" aria-label="Quick timer choices">
                <div class="timer-choice-grid">
                    @foreach (var grp in Model.Groups)
                    {
                        @foreach (var item in grp.Items)
                        {
                            <div class="timer-choice" onclick="timer.startDefaultTimer(@item.Length, '@item.Type.ToString()')">
                                <div class="numbers">
                                    @item.Length min
                                </div>
                                <div class="title">
                                    <img src="/icons/@(item.Type.ToString().ToLowerInvariant())-b.png" alt="@item.Type timer" />
                                </div>
                            </div>
                        }
                    }
                </div>
            </aside>
        </div>
    </div>
</div>


@section Scripts
{
    <script>
        let timer; // Declare timer at global scope

        // Initialize timer when DOM is ready
        document.addEventListener('DOMContentLoaded', function() {
            timer = new Preset(
                document.querySelector("#timer-go")
            );
        });

       function menuUpdate()
       {
                outOfScrollPosition(document.querySelector("#gbmainbg"), document.querySelector("#menu"));
                outOfScrollPosition(document.querySelector("#gbmainbg"), document.querySelector("#loc"));
       }

       $(document).ready(function () {
                document.querySelector("#gbmainbg").style.backgroundImage = "url(/bg-lib/index.jpg)";
           menuUpdate();
        })

        $(window).resize(() => menuUpdate());
    </script>
}
